# ============================================================
# Environment Variables — COPY THIS TO .env AND FILL IN VALUES
# NEVER commit .env to source control.
# ============================================================

# -----------------------------------------------------------
# App
# -----------------------------------------------------------
APP_VERSION=2.0.0
ENVIRONMENT=production    # development | production
DEBUG=false

# Public URL (no trailing slash) — must be HTTPS in production
# e.g. https://provident-copilot.onrender.com
PUBLIC_URL=https://YOUR_DOMAIN_HERE

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=["https://YOUR_DOMAIN_HERE"]

# -----------------------------------------------------------
# Security
# -----------------------------------------------------------
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET

# -----------------------------------------------------------
# Microsoft 365 / Azure AD App Registration
# Get from: Azure Portal > Azure Active Directory > App Registrations
# -----------------------------------------------------------
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# -----------------------------------------------------------
# OpenAI
# Get from: https://platform.openai.com/api-keys
# -----------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------
# Database
# For Docker Compose, this is set automatically in docker-compose.yml.
# For Render, paste your Render Postgres connection string here.
# For Supabase, use your Session Pooler connection string (port 5432).
# -----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://provident:provident_secret@localhost:5432/provident_db

# Postgres (used by docker-compose.yml to create the DB)
POSTGRES_USER=provident
POSTGRES_PASSWORD=provident_secret
POSTGRES_DB=provident_db

# -----------------------------------------------------------
# Scheduling
# -----------------------------------------------------------
CHECK_INTERVAL_MINUTES=15
LOOKBACK_MINUTES=30

# -----------------------------------------------------------
# Monitoring (optional)
# -----------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO

# -----------------------------------------------------------
# Gunicorn (optional — defaults shown)
# -----------------------------------------------------------
GUNICORN_WORKERS=2
