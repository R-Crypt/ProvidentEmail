# Microsoft 365 / Azure AD App Registration
# Get these from: Azure Portal > Azure Active Directory > App Registrations
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Sentry for error tracking
SENTRY_DSN=your-sentry-dsn-here

# App Settings
CHECK_INTERVAL_MINUTES=15
LOG_LEVEL=INFO

# Supabase Auth Settings (for POC Web Dashboard authentication)
SUPABASE_URL=https://vkensxazltfyweijkywi.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
